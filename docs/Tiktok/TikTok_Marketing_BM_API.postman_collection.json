	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Collection-level pre-request: ensure base variables are set",
					"const requiredVars = ['base_url', 'app_id'];",
					"const missing = requiredVars.filter(v => !pm.collectionVariables.get(v) || pm.collectionVariables.get(v).startsWith('YOUR_'));",
					"if (missing.length > 0) {",
					"    console.warn('⚠️ Missing or placeholder variables:', missing.join(', '));",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Collection-level test: check TikTok API response code",
					"if (pm.response && pm.response.code === 200) {",
					"    try {",
					"        const json = pm.response.json();",
					"        if (json.code && json.code !== 0) {",
					"            console.error(`✗ TikTok API error code=${json.code}: ${json.message}`);",
					"            if (json.code === 40100) {",
					"                console.error('→ Access token invalid or revoked. Re-run Auth A1.');",
					"            } else if (json.code === 40001) {",
					"                console.error('→ Parameter error. Check field names/values.');",
					"            } else if (json.code === 50002) {",
					"                console.error('→ Rate limit exceeded. Back off and retry.');",
					"            }",
					"        }",
					"    } catch (e) {",
					"        // Not JSON, skip",
					"    }",
					"}"
				]
			}
		}
