					"name": "R7a - Async Report Task Create",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const json = pm.response.json();",
									"if (json.code === 0 && json.data && json.data.task_id) {",
									"    pm.collectionVariables.set('task_id', json.data.task_id);",
									"    console.log('✓ task_id saved:', json.data.task_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Access-Token",
								"value": "{{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"advertiser_id\": \"{{advertiser_id}}\",\n    \"report_type\": \"BASIC\",\n    \"data_level\": \"AUCTION_CAMPAIGN\",\n    \"dimensions\": [\"campaign_id\", \"stat_time_day\"],\n    \"metrics\": [\"spend\", \"impressions\", \"clicks\", \"conversion\"],\n    \"start_date\": \"2026-01-01\",\n    \"end_date\": \"2026-03-31\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/report/task/create/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"report",
								"task",
								"create",
								""
							]
						},
						"description": "Create async report task for date ranges > 30 days or result > 20,000 rows.\n\n**Use case:** Historical backfill when first integrating an advertiser.\n\n**Workflow:**\n1. POST /report/task/create/ → get task_id\n2. Poll GET /report/task/check/ every 30s (max 30 min)\n3. When status=SUCCESS → GET /report/task/get/ (paginated)\n\n**Test script** saves `task_id` to collection variable for next steps."
					},
					"response": []
				},
				{
					"name": "R7b - Async Report Task Check",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Access-Token",
								"value": "{{access_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/report/task/check/?advertiser_id={{advertiser_id}}&task_id={{task_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"report",
								"task",
								"check",
								""
							],
							"query": [
								{
									"key": "advertiser_id",
									"value": "{{advertiser_id}}"
								},
								{
									"key": "task_id",
									"value": "{{task_id}}"
								}
							]
						},
						"description": "Check status of async report task.\n\n**Status values:**\n- `QUEUING` — waiting to run\n- `PROCESSING` — running\n- `SUCCESS` — done, ready to fetch via R7c\n- `FAILED` — error, check `error_message`\n- `CANCELED` — user canceled\n\nPoll every 30s until SUCCESS or FAILED. Max timeout 30 min."
					},
					"response": []
				},
				{
					"name": "R7c - Async Report Task Get",
					"request": {
