  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-calculate date variables",
          "var today = new Date();",
          "",
          "// Yesterday",
          "var yesterday = new Date(today);",
          "yesterday.setDate(yesterday.getDate() - 1);",
          "pm.environment.set('yesterday', yesterday.toISOString().split('T')[0]);",
          "",
          "// Two days ago (for user-level API which needs 8hr delay)",
          "var twoDaysAgo = new Date(today);",
          "twoDaysAgo.setDate(twoDaysAgo.getDate() - 2);",
          "pm.environment.set('two_days_ago', twoDaysAgo.toISOString().split('T')[0]);",
          "",
          "// Week ago",
          "var weekAgo = new Date(today);",
          "weekAgo.setDate(weekAgo.getDate() - 7);",
          "pm.environment.set('week_ago', weekAgo.toISOString().split('T')[0]);",
          "",
          "// Two weeks ago",
          "var twoWeeksAgo = new Date(today);",
          "twoWeeksAgo.setDate(twoWeeksAgo.getDate() - 14);",
          "pm.environment.set('two_weeks_ago', twoWeeksAgo.toISOString().split('T')[0]);",
          "",
          "// Month ago (within 45 day window)",
          "var monthAgo = new Date(today);",
          "monthAgo.setDate(monthAgo.getDate() - 30);",
          "pm.environment.set('month_ago', monthAgo.toISOString().split('T')[0]);",
          "",
          "// 45 days ago (max window)",
          "var maxWindow = new Date(today);",
          "maxWindow.setDate(maxWindow.getDate() - 44);",
          "pm.environment.set('max_window_start', maxWindow.toISOString().split('T')[0]);"
        ]
      }
    }
  ]
}
