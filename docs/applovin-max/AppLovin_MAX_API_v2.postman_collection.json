{
  "info": {
    "_postman_id": "applovin-max-v2-mediation-pro",
    "name": "AppLovin MAX API Collection v2 - Mediation Pro",
    "description": "Complete collection for AppLovin MAX APIs based on official documentation (support.axon.ai).\n\n## Quick Start\n1. Import this collection\n2. Import the environment file\n3. Set your Report Key in environment\n4. Run Health Checks first\n\n## APIs Included\n- Revenue Reporting API\n- Cohort API\n- User-Level Ad Revenue API\n- Ad Unit Management API\n\n## Official Docs\nhttps://support.axon.ai/en/max/reporting-apis/",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Health Checks",
      "item": [
        {
          "name": "Verify Report API Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has code 200', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    console.log('✅ Report API Key is VALID');",
                  "} else {",
                  "    console.log('❌ Report API Key verification FAILED');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{report_base_url}}/maxReport?api_key={{report_api_key}}&start={{yesterday}}&end={{yesterday}}&columns=day&format=json",
              "host": ["{{report_base_url}}"],
              "path": ["maxReport"],
              "query": [
                {"key": "api_key", "value": "{{report_api_key}}"},
                {"key": "start", "value": "{{yesterday}}"},
                {"key": "end", "value": "{{yesterday}}"},
                {"key": "columns", "value": "day"},
                {"key": "format", "value": "json"}
              ]
            },
            "description": "Minimal request to verify Report API key validity"
          }
        },
        {
          "name": "Verify Management API Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    console.log('✅ Management API Key is VALID');",
                  "} else if (pm.response.code === 401) {",
                  "    console.log('❌ Management API Key is INVALID');",
                  "} else {",
                  "    console.log('⚠️ Unexpected response: ' + pm.response.code);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {"key": "Api-Key", "value": "{{management_api_key}}"}
            ],
            "url": {
              "raw": "{{management_base_url}}/mediation/v1/ad_units",
              "host": ["{{management_base_url}}"],
              "path": ["mediation", "v1", "ad_units"]
            },
            "description": "Verify Management API key (requires Management Key, not Report Key)"
          }
        }
      ]
    },
    {
      "name": "02 - Revenue Reporting API",
      "description": "Revenue Reporting API - https://r.applovin.com/maxReport\n\nRequest window: 45 days\nTimezone: UTC\nData freshness: 1-2 hours delay",
      "item": [
        {
          "name": "Basic - Day + Application + Revenue",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "console.log('Records: ' + data.count);",
                  "if (data.results && data.results.length > 0) {",
                  "    var total = data.results.reduce((s,r) => s + parseFloat(r.estimated_revenue || 0), 0);",
                  "    console.log('Total Revenue: $' + total.toFixed(2));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
