            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{adset_id}}",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "{{adset_id}}"]
            }
          }
        }
      ]
    },
