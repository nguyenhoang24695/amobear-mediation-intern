{
  "info": {
    "_postman_id": "meta-marketing-api-mediation-pro",
    "name": "Meta Marketing API - Mediation Pro Platform",
    "description": "Complete Postman collection for Meta Marketing API integration.\n\n## Setup Instructions\n\n1. Create environment with variables:\n   - base_url: https://graph.facebook.com/v24.0\n   - access_token: Your long-lived access token\n   - app_id, app_secret, ad_account_id, page_id\n\n2. Import this collection and select environment\n\n## API Version: v24.0 (Released Oct 8, 2025)\n## Updated: Feb 2026\n\n## Important v24.0 Changes:\n- Legacy ASC/AAC APIs deprecated\n- Use OUTCOME_APP_PROMOTION for app installs\n- lookalike_spec mandatory from Jan 6, 2026\n- 5% budget can go to excluded placements",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{"key": "token", "value": "{{access_token}}", "type": "string"}]
  },
  "item": [
    {
      "name": "01. Authentication",
      "item": [
        {
          "name": "Exchange Token (Short to Long)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://graph.facebook.com/v24.0/oauth/access_token?grant_type=fb_exchange_token&client_id={{app_id}}&client_secret={{app_secret}}&fb_exchange_token={{short_lived_token}}",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "oauth", "access_token"],
              "query": [
                {"key": "grant_type", "value": "fb_exchange_token"},
                {"key": "client_id", "value": "{{app_id}}"},
                {"key": "client_secret", "value": "{{app_secret}}"},
                {"key": "fb_exchange_token", "value": "{{short_lived_token}}"}
              ]
            }
          }
        },
        {
          "name": "Debug Token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://graph.facebook.com/v24.0/debug_token?input_token={{access_token}}&access_token={{app_id}}|{{app_secret}}",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "debug_token"],
              "query": [
                {"key": "input_token", "value": "{{access_token}}"},
                {"key": "access_token", "value": "{{app_id}}|{{app_secret}}"}
              ]
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://graph.facebook.com/v24.0/me?fields=id,name,email",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "me"],
              "query": [{"key": "fields", "value": "id,name,email"}]
            }
          }
        }
      ]
    },
    {
      "name": "02. Ad Accounts",
      "item": [
        {
          "name": "List Ad Accounts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://graph.facebook.com/v24.0/me/adaccounts?fields=id,name,account_status,currency,timezone_name,amount_spent,business&limit=100",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "me", "adaccounts"],
              "query": [
                {"key": "fields", "value": "id,name,account_status,currency,timezone_name,amount_spent,business"},
                {"key": "limit", "value": "100"}
              ]
            }
          }
        },
        {
          "name": "Get Ad Account Details",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{ad_account_id}}?fields=id,name,account_status,currency,timezone_name,spend_cap,business,disable_reason",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "{{ad_account_id}}"],
              "query": [{"key": "fields", "value": "id,name,account_status,currency,timezone_name,spend_cap,business,disable_reason"}]
            }
          }
        }
      ]
    },
    {
      "name": "03. Campaigns",
      "item": [
        {
          "name": "List All Campaigns",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{ad_account_id}}/campaigns?fields=id,name,objective,status,daily_budget,lifetime_budget,bid_strategy,effective_status,special_ad_categories,created_time&limit=100",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "{{ad_account_id}}", "campaigns"],
              "query": [
                {"key": "fields", "value": "id,name,objective,status,daily_budget,lifetime_budget,bid_strategy,effective_status,special_ad_categories,created_time"},
                {"key": "limit", "value": "100"}
              ]
            }
          }
        },
        {
          "name": "List Active Campaigns",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{ad_account_id}}/campaigns?fields=id,name,objective,status,daily_budget&filtering=[{\"field\":\"effective_status\",\"operator\":\"IN\",\"value\":[\"ACTIVE\"]}]",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "{{ad_account_id}}", "campaigns"],
              "query": [
                {"key": "fields", "value": "id,name,objective,status,daily_budget"},
                {"key": "filtering", "value": "[{\"field\":\"effective_status\",\"operator\":\"IN\",\"value\":[\"ACTIVE\"]}]"}
              ]
            }
          }
        },
        {
          "name": "Get Campaign",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{campaign_id}}?fields=id,name,objective,status,daily_budget,lifetime_budget,bid_strategy,adsets{id,name,status}",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "{{campaign_id}}"],
              "query": [{"key": "fields", "value": "id,name,objective,status,daily_budget,lifetime_budget,bid_strategy,adsets{id,name,status}"}]
            }
          }
        },
        {
          "name": "Create Campaign - App Promotion",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"App Install - Weather App - VN - Feb 2025\",\n  \"objective\": \"OUTCOME_APP_PROMOTION\",\n  \"status\": \"PAUSED\",\n  \"special_ad_categories\": [],\n  \"buying_type\": \"AUCTION\",\n  \"bid_strategy\": \"LOWEST_COST_WITHOUT_CAP\"\n}"
            },
            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{ad_account_id}}/campaigns",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "{{ad_account_id}}", "campaigns"]
            }
          }
        },
        {
          "name": "Create Campaign - With Budget",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Weather App - VN Android - Feb 2025\",\n  \"objective\": \"OUTCOME_APP_PROMOTION\",\n  \"status\": \"PAUSED\",\n  \"special_ad_categories\": [],\n  \"buying_type\": \"AUCTION\",\n  \"bid_strategy\": \"LOWEST_COST_WITHOUT_CAP\",\n  \"daily_budget\": 5000000\n}"
            },
            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{ad_account_id}}/campaigns",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "{{ad_account_id}}", "campaigns"]
            }
          }
        },
        {
          "name": "Update Campaign",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Campaign Name\",\n  \"status\": \"PAUSED\",\n  \"daily_budget\": 7500000\n}"
            },
            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{campaign_id}}",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "{{campaign_id}}"]
            }
          }
        },
        {
          "name": "Pause Campaign",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"status\": \"PAUSED\"}"},
            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{campaign_id}}",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "{{campaign_id}}"]
            }
          }
        },
        {
          "name": "Activate Campaign",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"status\": \"ACTIVE\"}"},
            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{campaign_id}}",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "{{campaign_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "04. Ad Sets",
      "item": [
        {
          "name": "List Ad Sets",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{ad_account_id}}/adsets?fields=id,name,campaign_id,status,daily_budget,optimization_goal,billing_event,targeting,start_time,end_time&limit=100",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "{{ad_account_id}}", "adsets"],
              "query": [
                {"key": "fields", "value": "id,name,campaign_id,status,daily_budget,optimization_goal,billing_event,targeting,start_time,end_time"},
                {"key": "limit", "value": "100"}
              ]
            }
          }
        },
        {
          "name": "List Ad Sets by Campaign",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{campaign_id}}/adsets?fields=id,name,status,daily_budget,targeting,optimization_goal",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "{{campaign_id}}", "adsets"],
              "query": [{"key": "fields", "value": "id,name,status,daily_budget,targeting,optimization_goal"}]
            }
          }
        },
        {
          "name": "Get Ad Set",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{adset_id}}?fields=id,name,campaign_id,status,daily_budget,optimization_goal,billing_event,targeting,promoted_object,ads{id,name,status}",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "{{adset_id}}"],
              "query": [{"key": "fields", "value": "id,name,campaign_id,status,daily_budget,optimization_goal,billing_event,targeting,promoted_object,ads{id,name,status}"}]
            }
          }
        },
        {
          "name": "Create Ad Set - VN Android",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"VN - Android - 18-45 - Gaming Interest\",\n  \"campaign_id\": \"{{campaign_id}}\",\n  \"status\": \"PAUSED\",\n  \"daily_budget\": 2000000,\n  \"billing_event\": \"IMPRESSIONS\",\n  \"optimization_goal\": \"APP_INSTALLS\",\n  \"bid_amount\": 5000,\n  \"targeting\": {\n    \"geo_locations\": {\"countries\": [\"VN\"]},\n    \"age_min\": 18,\n    \"age_max\": 45,\n    \"genders\": [0],\n    \"device_platforms\": [\"mobile\"],\n    \"user_os\": [\"Android\"],\n    \"publisher_platforms\": [\"facebook\", \"instagram\", \"audience_network\"],\n    \"facebook_positions\": [\"feed\", \"stories\", \"reels\"],\n    \"instagram_positions\": [\"stream\", \"story\", \"reels\"]\n  },\n  \"promoted_object\": {\n    \"application_id\": \"{{facebook_app_id}}\",\n    \"object_store_url\": \"https://play.google.com/store/apps/details?id=com.example.app\"\n  }\n}"
            },
            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{ad_account_id}}/adsets",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "{{ad_account_id}}", "adsets"]
            }
          }
        },
        {
          "name": "Create Ad Set - With Interest",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"VN - Android - Gaming Interest - 25-40\",\n  \"campaign_id\": \"{{campaign_id}}\",\n  \"status\": \"PAUSED\",\n  \"daily_budget\": 3000000,\n  \"billing_event\": \"IMPRESSIONS\",\n  \"optimization_goal\": \"APP_INSTALLS\",\n  \"targeting\": {\n    \"geo_locations\": {\"countries\": [\"VN\"], \"location_types\": [\"home\", \"recent\"]},\n    \"age_min\": 25,\n    \"age_max\": 40,\n    \"device_platforms\": [\"mobile\"],\n    \"user_os\": [\"Android\"],\n    \"publisher_platforms\": [\"facebook\", \"instagram\"],\n    \"flexible_spec\": [\n      {\n        \"interests\": [\n          {\"id\": \"6003139266461\", \"name\": \"Mobile games\"},\n          {\"id\": \"6003107902433\", \"name\": \"Games\"}\n        ]\n      }\n    ]\n  },\n  \"promoted_object\": {\n    \"application_id\": \"{{facebook_app_id}}\",\n    \"object_store_url\": \"https://play.google.com/store/apps/details?id=com.example.app\"\n  }\n}"
            },
            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{ad_account_id}}/adsets",
