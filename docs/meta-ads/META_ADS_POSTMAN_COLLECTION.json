    {
      "name": "07. Insights",
      "item": [
        {
          "name": "Account Insights - Last 7d",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://graph.facebook.com/v24.0/{{ad_account_id}}/insights?fields=impressions,reach,clicks,spend,cpc,cpm,ctr,frequency,actions,cost_per_action_type&date_preset=last_7d",
              "protocol": "https",
              "host": ["graph", "facebook", "com"],
              "path": ["v24.0", "{{ad_account_id}}", "insights"],
              "query": [
                {"key": "fields", "value": "impressions,reach,clicks,spend,cpc,cpm,ctr,frequency,actions,cost_per_action_type"},
                {"key": "date_preset", "value": "last_7d"}
              ]
            }
          }
        },
        {
          "name": "Campaign Insights - Date Range",
          "request": {
