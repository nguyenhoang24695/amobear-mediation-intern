        {
          "name": "Remove Page from BM",
          "request": {
            "method": "DELETE",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [{ "key": "page_id", "value": "{{page_id}}" }]
            },
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/pages",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "pages"]
            },
            "description": "Error 42001 nếu linked với IG business."
          }
        }
      ]
    },
    {
      "name": "06. Instagram Management",
      "item": [
        {
          "name": "List All IG Accounts",
