          }
        },
        {
          "name": "Remove IG Account from BM",
          "request": {
            "method": "DELETE",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [{ "key": "instagram_account", "value": "{{ig_account_id}}" }]
            },
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/instagram_accounts",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "instagram_accounts"]
            }
          }
        }
      ]
    },
