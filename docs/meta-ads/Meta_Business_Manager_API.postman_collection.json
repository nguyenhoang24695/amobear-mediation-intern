    {
      "name": "09. Business Asset Groups",
      "item": [
        {
          "name": "List Asset Groups",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/business_asset_groups?fields=id,name",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "business_asset_groups"],
