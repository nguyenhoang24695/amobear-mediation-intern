{
  "info": {
    "name": "Meta Business Manager API — Full Reference",
    "_postman_id": "meta-bm-api-2026-v2",
    "description": "Comprehensive Postman collection for managing Meta Business Manager via Graph API v25.0.\n\nSetup:\n1. Set {{access_token}} = your System User Token\n2. Set {{bm_id}} = your Business Manager ID\n3. Authorization uses Bearer token via header (NOT query params)\n\nAll endpoints tested against Graph API v25.0.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://graph.facebook.com/v25.0",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "YOUR_SYSTEM_USER_TOKEN",
      "type": "string",
      "description": "System User Token (non-expiring). Generate in BM Settings > System Users."
    },
    {
      "key": "bm_id",
      "value": "YOUR_BUSINESS_MANAGER_ID",
      "type": "string"
    },
    {
      "key": "ad_account_id",
      "value": "act_YOUR_AD_ACCOUNT_ID",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "BUSINESS_SCOPED_USER_ID",
      "type": "string"
    },
    {
      "key": "page_id",
      "value": "YOUR_PAGE_ID",
      "type": "string"
    },
    {
      "key": "system_user_id",
      "value": "SYSTEM_USER_ID",
      "type": "string"
    },
    {
      "key": "asset_group_id",
      "value": "ASSET_GROUP_ID",
      "type": "string"
    },
    {
      "key": "child_bm_id",
      "value": "CHILD_BM_ID",
      "type": "string"
    },
    {
      "key": "ig_account_id",
      "value": "INSTAGRAM_ACCOUNT_ID",
      "type": "string"
    },
    {
      "key": "extended_credit_id",
      "value": "EXTENDED_CREDIT_ID",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01. Business Manager — CRUD",
      "description": "Create, Read, Update Business Manager",
      "item": [
        {
          "name": "Get BM Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{bm_id}}?fields=id,name,primary_page,verification_status,created_time,created_by,updated_time,two_factor_type,vertical,vertical_id,timezone_id,profile_picture_uri,link",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}"],
              "query": [
                { "key": "fields", "value": "id,name,primary_page,verification_status,created_time,created_by,updated_time,two_factor_type,vertical,vertical_id,timezone_id,profile_picture_uri,link" }
              ]
            },
            "description": "Đọc thông tin chi tiết của Business Manager."
          }
        },
        {
          "name": "List My BMs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/me/businesses",
              "host": ["{{base_url}}"],
              "path": ["me", "businesses"]
            },
            "description": "Liệt kê tất cả BMs mà user/system user có quyền access."
          }
        },
        {
          "name": "Create New BM",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "name", "value": "Amobear BM", "description": "Tên BM (required)" },
                { "key": "vertical", "value": "GAMING", "description": "Ngành nghề (required)" },
                { "key": "primary_page", "value": "{{page_id}}", "description": "Page ID đại diện BM" },
                { "key": "timezone_id", "value": "175", "description": "Vietnam timezone" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/me/businesses",
              "host": ["{{base_url}}"],
              "path": ["me", "businesses"]
            },
            "description": "Tạo BM mới. Cần business_management permission. Dev mode: max 2 child BMs."
          }
        },
        {
          "name": "Update BM",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "name", "value": "Amobear Updated", "description": "Tên BM mới" },
                { "key": "vertical", "value": "GAMING" },
                { "key": "two_factor_type", "value": "admin_required", "description": "none | admin_required | all_required" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/{{bm_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}"]
            },
            "description": "Cập nhật thông tin BM."
          }
        }
      ]
    },
    {
      "name": "02. Business Users — People Management",
      "description": "Manage business users (người thật) trong BM",
      "item": [
        {
          "name": "List All Business Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/business_users?fields=id,name,email,role,first_name,last_name,title&summary=total_count",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "business_users"],
              "query": [
                { "key": "fields", "value": "id,name,email,role,first_name,last_name,title" },
                { "key": "summary", "value": "total_count" }
              ]
            },
            "description": "Liệt kê users trong BM. Cần Advanced Access."
          }
        },
        {
          "name": "Invite User (ADMIN)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "email", "value": "admin@amobear.com", "description": "Email (required)" },
                { "key": "role", "value": "ADMIN" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/business_users",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "business_users"]
            },
            "description": "Invite user ADMIN. Rate limited — error 17 = đợi 24h."
          }
        },
        {
          "name": "Invite User (EMPLOYEE)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "email", "value": "employee@amobear.com" },
                { "key": "role", "value": "EMPLOYEE" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/business_users",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "business_users"]
            }
          }
        },
        {
          "name": "List Pending Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/pending_users?fields=id,email,role,status",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "pending_users"],
              "query": [
                { "key": "fields", "value": "id,email,role,status" }
              ]
            }
          }
        },
        {
          "name": "Change User Role",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "role", "value": "ADMIN", "description": "ADMIN | EMPLOYEE" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{user_id}}"]
            }
          }
        },
        {
          "name": "Remove User from BM",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{user_id}}"]
            },
            "description": "Không xóa được admin cuối cùng (error 3914)."
          }
        },
        {
          "name": "Cancel Pending Invite",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{user_id}}"]
            },
            "description": "Dùng pending_user_id."
          }
        }
      ]
    },
    {
      "name": "03. System Users",
      "description": "Manage system users (server/bot accounts)",
      "item": [
        {
          "name": "List System Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/system_users?fields=id,name,role&summary=total_count",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "system_users"],
              "query": [
                { "key": "fields", "value": "id,name,role" },
                { "key": "summary", "value": "total_count" }
              ]
            }
          }
        },
        {
          "name": "Create System User (ADMIN)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "name", "value": "Nexus Automation Bot", "description": "Required" },
                { "key": "role", "value": "ADMIN", "description": "ADMIN | EMPLOYEE" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/system_users",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "system_users"]
            },
            "description": "App phải được BM claim trước (error 104001)."
          }
        },
        {
          "name": "Create System User (EMPLOYEE)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "name", "value": "Nexus Read-Only Bot" },
                { "key": "role", "value": "EMPLOYEE" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/system_users",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "system_users"]
            }
          }
        }
      ]
    },
    {
      "name": "04. Ad Account Management",
      "description": "Claim, create, list, assign users to ad accounts",
      "item": [
        {
          "name": "List Owned Ad Accounts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/owned_ad_accounts?fields=id,account_id,name,account_status,currency,timezone_id,amount_spent,balance,business,permitted_tasks,access_type&limit=100",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "owned_ad_accounts"],
              "query": [
                { "key": "fields", "value": "id,account_id,name,account_status,currency,timezone_id,amount_spent,balance,business,permitted_tasks,access_type" },
                { "key": "limit", "value": "100" }
              ]
            }
          }
        },
        {
          "name": "List Pending Ad Accounts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/pending_owned_ad_accounts",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "pending_owned_ad_accounts"]
            }
          }
        },
        {
          "name": "⚠️ Claim Existing Ad Account (IRREVERSIBLE)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "adaccount_id", "value": "act_123456789", "description": "Format: act_XXXXXXXXX" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/owned_ad_accounts",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "owned_ad_accounts"]
            },
            "description": "⚠️ IRREVERSIBLE: OWNER status không thể undo. Test sandbox trước!"
          }
        },
        {
          "name": "Create New Ad Account (Limit 5)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "name", "value": "Amobear - WeatherApp US" },
                { "key": "currency", "value": "USD" },
                { "key": "timezone_id", "value": "1" },
                { "key": "end_advertiser", "value": "{{bm_id}}", "description": "Business ID, NONE, or UNFOUND" },
                { "key": "media_agency", "value": "NONE" },
                { "key": "partner", "value": "NONE" },
                { "key": "invoice", "value": "false", "description": "true = attach to credit line" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/adaccount",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "adaccount"]
            },
            "description": "Max 5 ad accounts via API."
          }
        },
        {
          "name": "Assign User to Ad Account",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "user", "value": "{{user_id}}" },
                { "key": "tasks", "value": "[\"MANAGE\",\"ADVERTISE\",\"ANALYZE\"]", "description": "JSON array" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/{{ad_account_id}}/assigned_users",
              "host": ["{{base_url}}"],
              "path": ["{{ad_account_id}}", "assigned_users"]
            },
            "description": "Also used to change existing permissions (overwrite)."
          }
        },
        {
          "name": "List Assigned Users on Ad Account",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{ad_account_id}}/assigned_users?fields=id,name,email,tasks",
              "host": ["{{base_url}}"],
              "path": ["{{ad_account_id}}", "assigned_users"],
              "query": [
                { "key": "fields", "value": "id,name,email,tasks" }
              ]
            }
          }
        },
        {
          "name": "List User's Assigned Ad Accounts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{user_id}}/assigned_ad_accounts?fields=id,name,account_status",
              "host": ["{{base_url}}"],
              "path": ["{{user_id}}", "assigned_ad_accounts"],
              "query": [
                { "key": "fields", "value": "id,name,account_status" }
              ]
            }
          }
        },
        {
          "name": "Remove User from Ad Account",
          "request": {
            "method": "DELETE",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "user", "value": "{{user_id}}" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/{{ad_account_id}}/assigned_users",
              "host": ["{{base_url}}"],
              "path": ["{{ad_account_id}}", "assigned_users"]
            }
          }
        },
        {
          "name": "Remove Ad Account from BM",
          "request": {
            "method": "DELETE",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "adaccount_id", "value": "{{ad_account_id}}" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/ad_accounts",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "ad_accounts"]
            },
            "description": "⚠️ Only works for AGENCY access or PENDING status."
          }
        }
      ]
    },
    {
      "name": "05. Page Management",
      "item": [
        {
          "name": "List Owned Pages",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/{{bm_id}}/owned_pages?fields=id,name,category,fan_count",
              "host": ["{{base_url}}"],
              "path": ["{{bm_id}}", "owned_pages"],
              "query": [{ "key": "fields", "value": "id,name,category,fan_count" }]
