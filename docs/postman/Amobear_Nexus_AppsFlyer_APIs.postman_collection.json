{
	"info": {
		"_postman_id": "f9a0b1c2-af-nexus-2026-collection",
		"name": "Amobear Nexus — AppsFlyer APIs",
		"description": "Postman collection cho AppsFlyer API integration vào Amobear Nexus.\n\nDoc reference: 128 — AppsFlyer Integration\n\n## Setup\n1. Dashboard → Integration → API Access → Copy API V2 Token\n2. Set biến `api_token` trong Environment\n3. Set `app_id` = bundle ID (Android) hoặc idXXX (iOS)\n\n## Authentication\n- Pull API: Token trong query param `api_token`\n- Master API & Cohort API: `Authorization: Bearer {token}`\n\n## Rate Limits\n- Pull API: 10 calls/min per app\n- Master API: 40 calls/min\n- Cohort API: 5 calls/min\n\n## Date Format: YYYY-MM-DD\n## Response: CSV (Pull API) or JSON (Master/Cohort API)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "pull_base_url",
			"value": "https://hq1.appsflyer.com",
			"type": "string"
		},
		{
			"key": "master_base_url",
			"value": "https://hq1.appsflyer.com",
			"type": "string"
		},
		{
			"key": "cohort_base_url",
			"value": "https://hq1.appsflyer.com",
			"type": "string"
		},
		{
			"key": "api_token",
			"value": "YOUR_API_V2_TOKEN_HERE",
			"type": "string",
			"description": "AppsFlyer API V2 Token — Dashboard → Integration → API Access"
		},
		{
			"key": "app_id",
			"value": "com.amobear.puzzlegame",
			"type": "string",
			"description": "Android: com.package.name — iOS: id1234567890"
		},
		{
			"key": "from_date",
			"value": "2026-04-01",
			"type": "string"
		},
		{
			"key": "to_date",
			"value": "2026-04-07",
			"type": "string"
		},
		{
			"key": "nexus_webhook_local",
			"value": "http://localhost:5000/api/webhooks/appsflyer",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "01 — Pull API: Raw Data (Non-organic)",
			"description": "Raw install-level data with attribution. CSV response.\n\nBase URL: https://hq1.appsflyer.com/api/raw-data/export/app/\n\n⚠️ Max 90 days range. Max 1M rows per request.",
			"item": [
				{
					"name": "1.1 Non-organic Installs",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{pull_base_url}}/api/raw-data/export/app/{{app_id}}/installs_report/v5?api_token={{api_token}}&from={{from_date}}&to={{to_date}}&currency=preferred",
							"host": ["{{pull_base_url}}"],
							"path": ["api", "raw-data", "export", "app", "{{app_id}}", "installs_report", "v5"],
							"query": [
								{"key": "api_token", "value": "{{api_token}}"},
								{"key": "from", "value": "{{from_date}}"},
								{"key": "to", "value": "{{to_date}}"},
								{"key": "currency", "value": "preferred"}
							]
						},
						"description": "Paid/attributed installs. Each row = 1 install event.\n\nKey fields: media_source, campaign, campaign_id, adset, ad, country_code, install_time, appsflyer_id.\n\n**Nexus use:** Primary source for UA attribution data → bronze.appsflyer_installs_raw"
					}
				},
				{
					"name": "1.2 Non-organic Installs (with additional fields)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{pull_base_url}}/api/raw-data/export/app/{{app_id}}/installs_report/v5?api_token={{api_token}}&from={{from_date}}&to={{to_date}}&additional_fields=device_download_time,deeplink_url,oaid,install_app_store,match_type,contributor1_media_source,contributor1_campaign,keyword_id,store_reinstall,impressions,custom_data&currency=preferred",
							"host": ["{{pull_base_url}}"],
							"path": ["api", "raw-data", "export", "app", "{{app_id}}", "installs_report", "v5"],
							"query": [
								{"key": "api_token", "value": "{{api_token}}"},
								{"key": "from", "value": "{{from_date}}"},
								{"key": "to", "value": "{{to_date}}"},
								{"key": "additional_fields", "value": "device_download_time,deeplink_url,oaid,install_app_store,match_type,contributor1_media_source,contributor1_campaign,keyword_id,store_reinstall,impressions,custom_data"},
								{"key": "currency", "value": "preferred"}
							]
						},
						"description": "Installs with additional fields. Note: additional_fields are NOT included by default.\n\nUseful extras: match_type (fingerprint/id_matching), contributor fields (multi-touch), deeplink_url."
					}
				},
				{
					"name": "1.3 Non-organic In-app Events",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{pull_base_url}}/api/raw-data/export/app/{{app_id}}/in_app_events_report/v5?api_token={{api_token}}&from={{from_date}}&to={{to_date}}&currency=preferred",
							"host": ["{{pull_base_url}}"],
							"path": ["api", "raw-data", "export", "app", "{{app_id}}", "in_app_events_report", "v5"],
							"query": [
								{"key": "api_token", "value": "{{api_token}}"},
								{"key": "from", "value": "{{from_date}}"},
								{"key": "to", "value": "{{to_date}}"},
								{"key": "currency", "value": "preferred"}
							]
						},
						"description": "In-app events (purchases, level_complete, etc.) with attribution.\n\nKey fields: event_name, event_value (JSON), event_revenue, event_revenue_usd, media_source.\n\n**Nexus use:** Track post-install user value by media source."
					}
				},
				{
					"name": "1.4 In-app Events (filtered by event name)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{pull_base_url}}/api/raw-data/export/app/{{app_id}}/in_app_events_report/v5?api_token={{api_token}}&from={{from_date}}&to={{to_date}}&event_name=af_purchase,af_subscribe&currency=preferred",
							"host": ["{{pull_base_url}}"],
							"path": ["api", "raw-data", "export", "app", "{{app_id}}", "in_app_events_report", "v5"],
							"query": [
								{"key": "api_token", "value": "{{api_token}}"},
								{"key": "from", "value": "{{from_date}}"},
								{"key": "to", "value": "{{to_date}}"},
								{"key": "event_name", "value": "af_purchase,af_subscribe"},
								{"key": "currency", "value": "preferred"}
							]
						},
						"description": "Filter by specific events. Comma-separated event names.\n\nCommon events: af_purchase, af_subscribe, af_level_achieved, af_tutorial_completion, af_ad_view."
					}
				},
				{
					"name": "1.5 Uninstalls",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{pull_base_url}}/api/raw-data/export/app/{{app_id}}/uninstall_events_report/v5?api_token={{api_token}}&from={{from_date}}&to={{to_date}}",
							"host": ["{{pull_base_url}}"],
							"path": ["api", "raw-data", "export", "app", "{{app_id}}", "uninstall_events_report", "v5"],
							"query": [
								{"key": "api_token", "value": "{{api_token}}"},
								{"key": "from", "value": "{{from_date}}"},
								{"key": "to", "value": "{{to_date}}"}
							]
						},
						"description": "Uninstall events with attribution. Identify which campaigns drive high uninstall rates.\n\n**Nexus use:** Churn analysis by media source."
					}
				},
				{
					"name": "1.6 Reinstalls",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{pull_base_url}}/api/raw-data/export/app/{{app_id}}/reinstalls/v5?api_token={{api_token}}&from={{from_date}}&to={{to_date}}",
							"host": ["{{pull_base_url}}"],
							"path": ["api", "raw-data", "export", "app", "{{app_id}}", "reinstalls", "v5"],
							"query": [
								{"key": "api_token", "value": "{{api_token}}"},
								{"key": "from", "value": "{{from_date}}"},
								{"key": "to", "value": "{{to_date}}"}
							]
						},
						"description": "Reinstall events."
					}
				}
			]
		},
