		{
			"name": "09 — Cohort API (POST)",
			"description": "Cohort API cho chi tiết hơn Master API cohort KPIs.\nPOST with JSON body. Auth via header.\n\n⚠️ Rate limit: 5 calls/min.\n⚠️ Chỉ 1 KPI per call (tất cả functions trả về).",
			"item": [
				{
					"name": "9.1 Revenue Cohort ALL APPS (D0-D30)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{api_token}}", "type": "text"},
							{"key": "Content-Type", "value": "application/json", "type": "text"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"cohort_type\": \"user_acquisition\",\n  \"min_cohort_size\": 1,\n  \"preferred_timezone\": false,\n  \"from\": \"{{from_date}}\",\n  \"to\": \"{{to_date}}\",\n  \"granularity\": \"day\",\n  \"groupings\": [\"af_app_id\", \"date\", \"pid\", \"geo\"],\n  \"filters\": {\n    \"period\": [0, 1, 3, 7, 14, 30],\n    \"partial_data\": \"excluded\"\n  },\n  \"kpis\": [\"revenue\"],\n  \"aggregation_type\": \"cumulative\",\n  \"per_user\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/cohorts/v1/data/app/all?format=csv",
							"host": ["{{base_url}}"],
							"path": ["api", "cohorts", "v1", "data", "app", "all"],
							"query": [
								{"key": "format", "value": "csv"}
							]
						},
						"description": "Cohort API: Revenue per user cumulative at D0/D1/D3/D7/D14/D30.\nGrouped by app × date × media_source × geo.\n\nper_user=true → revenue per user (for LTV).\nper_user=false → total revenue (for absolute numbers).\n\nNexus use: Weekly LTV pipeline — more granular than Master API cohort KPIs."
					}
				},
				{
					"name": "9.2 Retention Cohort ALL APPS (sessions on-day)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{api_token}}", "type": "text"},
							{"key": "Content-Type", "value": "application/json", "type": "text"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"cohort_type\": \"user_acquisition\",\n  \"min_cohort_size\": 10,\n  \"preferred_timezone\": false,\n  \"from\": \"{{from_date}}\",\n  \"to\": \"{{to_date}}\",\n  \"granularity\": \"day\",\n  \"groupings\": [\"af_app_id\", \"date\", \"pid\"],\n  \"filters\": {\n    \"period\": [1, 3, 7, 14, 30],\n    \"partial_data\": \"excluded\"\n  },\n  \"kpis\": [\"sessions\"],\n  \"aggregation_type\": \"on_day\",\n  \"per_user\": false\n}"
						},
