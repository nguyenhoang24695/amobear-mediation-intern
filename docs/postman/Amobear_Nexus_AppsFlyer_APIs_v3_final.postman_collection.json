                "cohorts",
                "v1",
                "data",
                "app",
                "all"
              ],
              "query": [
                {
                  "key": "format",
                  "value": "csv"
                }
              ]
            },
            "description": "Cohort API: Revenue per user cumulative at D0/D1/D3/D7/D14/D30.\nGrouped by app \u00d7 date \u00d7 media_source \u00d7 geo.\n\nper_user=true \u2192 revenue per user (for LTV).\nper_user=false \u2192 total revenue (for absolute numbers).\n\nNexus use: Weekly LTV pipeline \u2014 more granular than Master API cohort KPIs."
          }
        },
        {
          "name": "9.2 Retention Cohort ALL APPS (sessions on-day)",
